framework:
  name: AI Structural Genetics
  short_name: ASG
  version: "0.1"
  status: draft
  language: en
  type: comparative-interpretive-framework
  domain:
    primary: ai_model_evolution
    secondary:
      - structural_analysis
      - model_lineage
      - multimodal_evolution
      - specialization_dynamics
  summary: >
    AI Structural Genetics is a comparative framework for interpreting
    the evolution of AI model families through structural continuity,
    divergence, mutation-like shifts, adaptation, and fusion.
    It does not claim literal biological inheritance, but provides
    an interpretive taxonomy for reading model development as
    lineage-like structural evolution.

principles:
  - id: P1
    name: Non-literal biology
    description: >
      Biological language is used as a comparative lens, not as a claim
      that AI systems are literally organisms.
  - id: P2
    name: Structure over branding
    description: >
      Model families should be analyzed through structural tendencies,
      architecture shifts, and capability patterns rather than only
      through release names or marketing labels.
  - id: P3
    name: Lineage over flat comparison
    description: >
      AI models are better understood as evolving families with
      continuity and divergence, not only as isolated benchmark entries.
  - id: P4
    name: Environment-sensitive development
    description: >
      Training corpora, deployment conditions, fine-tuning regimes,
      and usage ecosystems shape the developmental trajectory of models.
  - id: P5
    name: Interpretive rigor
    description: >
      The framework should distinguish clearly between observed facts,
      inferred structural tendencies, and metaphorical interpretation.

scope:
  included:
    model_families:
      - large_language_models
      - diffusion_models
      - language_specialized_models
      - multimodal_models
    analysis_targets:
      - lineage_patterns
      - architecture_transitions
      - specialization_paths
      - modular_extensions
      - fusion_patterns
      - ecosystem_branching
  excluded:
    - literal_biological_claims
    - strict_genetic_equivalence
    - unverified_weight_inheritance_claims
    - benchmark_only_rankings
    - legal_or_financial_attribution_rules
  boundary_note: >
    This framework is primarily interpretive and taxonomic.
    It is designed to organize structural understanding, not to prove
    direct causal inheritance unless supported by evidence.

comparative_mapping:
  genetic_basis:
    ai_correlate:
      - trained_weights
      - parameter_structure
      - latent_configuration
    note: >
      Refers to the internal learned basis that supports recurring
      behavioral tendencies across a model or family.
  phenotype_like_expression:
    ai_correlate:
      - observable_behavior
      - response_style
      - reasoning_tendency
      - multimodal_capability
    note: >
      Refers to externally visible tendencies expressed by the model.
  environment:
    ai_correlate:
      - training_data
      - synthetic_data
      - deployment_context
      - user_interaction_patterns
      - language_domain
    note: >
      Refers to the context that shapes specialization, robustness,
      and functional tendency.
  adaptation:
    ai_correlate:
      - fine_tuning
      - instruction_tuning
      - domain_specialization
      - alignment_adjustment
    note: >
      Refers to environment-sensitive changes that improve fit for
      particular tasks, languages, or usage conditions.
  mutation_like_shift:
    ai_correlate:
      - architectural_redesign
      - latent_space_reorganization
      - inference_pipeline_change
      - training_regime_shift
    note: >
      Refers to major structural transitions that alter model behavior
      or developmental direction.
  divergence:
    ai_correlate:
      - family_branching
      - open_vs_closed_development_paths
      - ecosystem_forking
      - derived_model_cultures
    note: >
      Refers to family-level branching into distinct developmental paths.
  fusion_evolution:
    ai_correlate:
      - multimodal_integration
      - modular_unification
      - language_vision_audio_convergence
    note: >
      Refers to the emergence of new structural capability through
      integration across distinct processing modes.
  horizontal_transfer_like_extension:
    ai_correlate:
      - lora
      - adapters
      - control_modules
      - external_tool_binding
    note: >
      Refers to module-like extensions that modify capability without
      fully rebuilding the base model.

core_patterns:
  continuity:
    label: Continuity
    definition: >
      A lineage-like persistence of structural or behavioral tendencies
      across successive model generations.
    indicators:
      - recurring capability signatures
      - stable family identity
      - progressive scaling with preserved traits
    typical_questions:
      - What remains stable across generations?
      - Which traits appear conserved?
  divergence:
    label: Divergence
    definition: >
      Branching of a model family into distinct developmental directions
      under different design priorities, ecosystems, or use cases.
    indicators:
      - family splits
      - ecosystem-specific derivatives
      - differing specialization paths
    typical_questions:
      - Where do branches separate?
      - What pressures drive family branching?
  mutation:
    label: Mutation-like Shift
    definition: >
      A major structural change that produces a noticeable shift in
      behavior, capability profile, or developmental trajectory.
    indicators:
      - architecture redesign
      - latent reorganization
      - pipeline restructuring
    typical_questions:
      - What changed structurally?
      - Did the family undergo a qualitative transition?
  adaptation:
    label: Adaptation
    definition: >
      Specialization in response to a particular linguistic, task, or
      deployment environment.
    indicators:
      - language specialization
      - instruction-following improvement
      - domain tuning
    typical_questions:
      - What environment is shaping this model?
      - Which niche is it adapting to?
  fusion:
    label: Fusion Evolution
    definition: >
      Integration of previously distinct modalities or subsystems into
      a more unified structural whole.
    indicators:
      - multimodal reasoning
      - cross-modal consistency
      - unified processing capabilities
    typical_questions:
      - What modes are being integrated?
      - What new expression emerges from that integration?
  extension:
    label: Horizontal Extension
    definition: >
      Module-like capability injection or overlay that changes behavior
      without full family redesign.
    indicators:
      - lora attachment
      - adapter injection
      - external controller layers
    typical_questions:
      - What was added externally?
      - Is the base lineage preserved beneath the extension?

analysis_dimensions:
  architecture:
    description: >
      Structural form of the model, including core design,
      inference pathway, and organization of internal computation.
  capability_profile:
    description: >
      The observable pattern of strengths and weaknesses across tasks.
  alignment_style:
    description: >
      Behavioral shaping related to safety, instruction following,
      refusal patterns, and interaction stability.
  language_ecology:
    description: >
      Degree and manner of adaptation to specific linguistic contexts.
  multimodal_integration:
    description: >
      Extent to which distinct input or processing modes are fused.
  modularity:
    description: >
      Degree to which the model can be extended through attached modules.
  openness_ecosystem:
    description: >
      How publication style, accessibility, and community fork culture
      affect developmental branching.
  lineage_visibility:
    description: >
      How clearly the family history can be reconstructed from
      documentation, architecture, and behavior.

evidence_model:
  observation_levels:
    L1_direct_documentation:
      description: >
        Public technical reports, model cards, official architecture notes,
        and documented release details.
    L2_behavioral_inference:
      description: >
        Inference based on repeated observable tendencies in outputs,
        benchmark profiles, or known deployment behavior.
    L3_structural_interpretation:
      description: >
        Higher-level interpretive modeling that organizes patterns into
        continuity, divergence, mutation, adaptation, or fusion.
  usage_rule: >
    Claims should ideally identify whether they belong to direct
    documentation, behavioral inference, or structural interpretation.

taxonomy:
  family_types:
    - id: F1
      name: Direct Continuity Family
      description: >
        A family primarily interpreted through continuity and progressive
        expansion of capability.
    - id: F2
      name: Branching Family
      description: >
        A family whose evolution is best understood through branching
        paths and ecosystem divergence.
    - id: F3
      name: Mutation-rich Family
      description: >
        A family exhibiting visible architecture-sensitive changes
        across generations.
    - id: F4
      name: Local Adaptation Family
      description: >
        A family shaped by domain, language, or deployment specialization.
    - id: F5
      name: Fusion Family
      description: >
        A family characterized by convergence across modalities
        or subsystem types.
    - id: F6
      name: Extension-dependent Family
      description: >
        A family whose practical phenotype is strongly influenced by
        add-on modules, adapters, or control layers.

example_interpretations:
  - model_group: GPT_family
    dominant_patterns:
      - continuity
      - adaptation
      - fusion
    interpretation_note: >
      Often read as a continuity-oriented family with expanding
      generality, interaction stability, and later multimodal integration.
    caution: >
      Do not assume direct weight inheritance unless publicly supported.
  - model_group: Llama_family
    dominant_patterns:
      - divergence
      - adaptation
    interpretation_note: >
      Useful as a branching family with strong ecosystem effects,
      openness dynamics, and derivative specialization.
  - model_group: Stable_Diffusion_family
    dominant_patterns:
      - mutation
      - extension
      - fusion
    interpretation_note: >
      Image-generation families often make mutation-like shifts and
      module-based extension especially visible.
  - model_group: Japanese_specialized_models
    dominant_patterns:
      - adaptation
    interpretation_note: >
      Suitable examples of local adaptation to a linguistic and
      cultural environment.
  - model_group: multimodal_models
    dominant_patterns:
      - fusion
      - continuity
    interpretation_note: >
      Best interpreted through convergence of previously distinct
      processing modes.

analysis_workflow:
  step_1:
    name: Identify family
    description: >
      Determine whether the target belongs to a recognizable model family,
      derivative lineage, or mixed ecosystem branch.
  step_2:
    name: Collect evidence
    description: >
      Separate direct documentation from behavioral inference.
  step_3:
    name: Map structural patterns
    description: >
      Classify the case using continuity, divergence, mutation,
      adaptation, fusion, and extension where applicable.
  step_4:
    name: Describe phenotype
    description: >
      Summarize the model's externally visible tendencies without
      overstating undocumented internals.
  step_5:
    name: Interpret cautiously
    description: >
      Mark which conclusions are empirical and which are interpretive.
  step_6:
    name: Place in taxonomy
    description: >
      Position the case within a family-type taxonomy and note overlap
      with other patterns.

output_schema:
  case_record:
    fields:
      - model_name
      - family_name
      - release_stage
      - dominant_patterns
      - evidence_level
      - structural_observations
      - phenotype_summary
      - environment_context
      - interpretation_note
      - caution_note
  family_record:
    fields:
      - family_name
      - lineage_type
      - major_branches
      - continuity_traits
      - mutation_points
      - adaptation_zones
      - fusion_layers
      - extension_ecosystem
      - visibility_level

terminology:
  continuity: >
    Persistence of recognizable structural or behavioral tendencies
    across generations.
  divergence: >
    Branching into distinct developmental paths.
  mutation: >
    Major qualitative structural shift.
  adaptation: >
    Specialization in response to environment.
  fusion: >
    Integration across distinct modalities or subsystems.
  extension: >
    Capability modification through attached or injected modules.
  lineage: >
    A family-like developmental trajectory across related models.
  phenotype: >
    Observable behavioral or capability tendency.
  environment: >
    The training and deployment context shaping specialization.

limits:
  - This framework does not prove biological inheritance.
  - This framework does not guarantee hidden-weight continuity.
  - This framework should not replace empirical documentation.
  - This framework is interpretive before it is predictive.
  - This framework should not be used to overstate unsupported claims.

future_extensions:
  v0_2_targets:
    - phylogenetic_diagram_schema
    - scoring_matrix_for_structural_patterns
    - family_comparison_template
    - lineage_visibility_index
    - mutation_severity_scale
    - adaptation_depth_scale
  v0_3_targets:
    - contribution_trace_linkage
    - structural_lineage_registry
    - interoperability_with_trace_frameworks
    - bridge_to_structural_royalty_models

repository_integration:
  recommended_files:
    - README.md
    - docs/overview.md
    - docs/core-concepts.md
    - docs/model-examples.md
    - docs/taxonomy.md
    - docs/evidence-model.md
    - spec/ai-structural-genetics.yaml
    - figures/phylogeny-draft.png
    - CHANGELOG.md
  publication_channels:
    note:
      role: japanese_introductory_and_conceptual_essays
    medium:
      role: english_framework_and_entry_articles
    github:
      role: fixed_definitions_taxonomy_and_versioned_structure

metadata:
  author_role: conceptual_designer
  maturity: early_foundation
  intended_use:
    - conceptual_mapping
    - structural_interpretation
    - comparative_analysis
    - future_taxonomy_development
  not_intended_for:
    - biological_literalism
    - unsupported_historical_assertion
    - standalone_scientific_proof
